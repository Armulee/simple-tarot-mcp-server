# --- Required in production ------------------------------------------------

# Secret used to sign access tokens + consent transactions (HS256).
# Generate with: openssl rand -base64 48
JWT_SECRET=

# OAuth state storage (oauth_clients / oauth_codes / oauth_refresh_tokens).
# Use Upstash Redis (or Vercel KV, which exposes the same REST API).
# Without these the server falls back to in-memory storage — fine for local
# dev, broken on serverless/multi-instance deployments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# ...or the Vercel KV names:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- askingfate.com account bridge (Supabase) --------------------------------

# The authorize endpoint signs users in against the SAME Supabase project as
# askingfate.com (same accounts: email/password and Google). Use the exact
# values from the main site's env. The NEXT_PUBLIC_-prefixed names work too.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# For "Continue with Google" to return here, add this deployment's callback to
# the Supabase project under Authentication -> URL Configuration -> Redirect
# URLs:   https://mcp.askingfate.com/oauth/callback

# --- Legacy bridge (only if the main site ever exposes a session endpoint) ---

# Fallback external login page used ONLY when the Supabase env above is
# missing. It must redirect back to the URL passed in the callback param.
# (The main site's page is /signin — it has no /login route.)
# ASKINGFATE_LOGIN_URL=https://askingfate.com/signin
# ASKINGFATE_LOGIN_CALLBACK_PARAM=callbackUrl

# Cookie-forwarding session endpoint on the main site. Off by default; only
# useful if the main site issues a session cookie with Domain=.askingfate.com.
# ASKINGFATE_SESSION_ENDPOINT=

# --- Optional ----------------------------------------------------------------

# Issuer override; defaults to the public origin derived from the request
# (proxy-header aware), e.g. https://mcp.askingfate.com
# OAUTH_ISSUER=https://mcp.askingfate.com

# Extra allowed redirect URIs (comma-separated). https://claude.ai and
# https://claude.com MCP callbacks are always allowed.
# OAUTH_ALLOWED_REDIRECT_URIS=

# Allow http://localhost / http://127.0.0.1 redirect URIs (MCP Inspector).
# Defaults to true outside production, false in production.
# OAUTH_ALLOW_LOOPBACK_REDIRECTS=false

# --- Local development only (ignored in production builds) -------------------

# Skip the askingfate session check and act as this logged-in user.
# OAUTH_DEV_USER_ID=user_dev_1
# OAUTH_DEV_USER_EMAIL=dev@askingfate.local

# Verbose MCP transport logs
# MCP_VERBOSE_LOGS=true
