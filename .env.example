# --- Required in production ------------------------------------------------

# Secret used to sign access tokens + consent transactions (HS256).
# Generate with: openssl rand -base64 48
JWT_SECRET=

# OAuth state storage (oauth_clients / oauth_codes / oauth_refresh_tokens).
# Use Upstash Redis (or Vercel KV, which exposes the same REST API).
# Without these the server falls back to in-memory storage — fine for local
# dev, broken on serverless/multi-instance deployments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# ...or the Vercel KV names:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- askingfate.com account bridge ------------------------------------------

# Where unauthenticated users are sent to log in. The login page must redirect
# back to the URL passed in the callback param after a successful login.
# ASKINGFATE_LOGIN_URL=https://askingfate.com/login
# ASKINGFATE_LOGIN_CALLBACK_PARAM=callbackUrl

# Session endpoint on the main site; the incoming Cookie header is forwarded
# to it. NOTE: the main site must issue its session cookie with
# Domain=.askingfate.com so that mcp.askingfate.com receives it.
# ASKINGFATE_SESSION_ENDPOINT=https://askingfate.com/api/auth/session

# --- Optional ----------------------------------------------------------------

# Issuer override; defaults to the public origin derived from the request
# (proxy-header aware), e.g. https://mcp.askingfate.com
# OAUTH_ISSUER=https://mcp.askingfate.com

# Extra allowed redirect URIs (comma-separated). https://claude.ai and
# https://claude.com MCP callbacks are always allowed.
# OAUTH_ALLOWED_REDIRECT_URIS=

# Allow http://localhost / http://127.0.0.1 redirect URIs (MCP Inspector).
# Defaults to true outside production, false in production.
# OAUTH_ALLOW_LOOPBACK_REDIRECTS=false

# --- Local development only (ignored in production builds) -------------------

# Skip the askingfate session check and act as this logged-in user.
# OAUTH_DEV_USER_ID=user_dev_1
# OAUTH_DEV_USER_EMAIL=dev@askingfate.local

# Verbose MCP transport logs
# MCP_VERBOSE_LOGS=true
